
@{
    ViewData["Title"] = "Reset";
    Layout = "~/Views/Shared/_Login.cshtml";
}

<div class="text-center">
    <h1 class="h4 text-gray-900 mb-4">Quên Mật Khẩu</h1>
</div>
<form class="user">
    <div class="form-group">
        <input type="password" class="form-control form-control-user"
               id="password"
               placeholder="Nhập mật khẩu mới">
    </div>
    <div class="form-group">
        <input type="password" class="form-control form-control-user"
               id="confirmpassword"
               placeholder="Nhập lại mật khẩu mới">
    </div>

    <input type="button" id="login" class="btn btn-primary btn-user btn-block" value="Xác nhận" />


</form>
<hr>

<div class="text-center">
    <a class="small" href="~/Login/Index">Quay về</a>
</div>

@section scripts {
    <script>
        var login = {
            init: function () {

                $("#login").click(function () {

                    login.reset();
                });
            },
            reset: function () {
               
                var password = $("#password").val();
                var confirmpassword = $("#confirmpassword").val();
                if( !password || !confirmpassword) {
                    alert("Vui lòng điền đầy đủ thông tin.");
                    return;
                }

                if (password != confirmpassword) {
                    alert("Mật khẩu không trùng khớp.");
                    return;
                }
                var form = new FormData()
               
                form.append("password", password);
                $("#loading").show();
                $.ajax({
                    type: 'POST',
                    dataType: 'Json',
                    contentType: false,
                    processData: false,
                    data: form,
                    url: '/Login/ResetPassword/',
                    success: function (res) {         
                        alert("Đổi mật khẩu mới thành công")
                        window.location.href = "/Login/Index";                
                        $("#loading").hide();
                    },
                });
            },
        }
        login.init();
    </script>
}

