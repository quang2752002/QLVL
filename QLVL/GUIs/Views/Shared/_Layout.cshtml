
<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="description" content="">
    <meta name="author" content="">

    <title>Tìm Việc</title>

    <!-- Custom fonts for this template-->
    <link href="~/Assets/Themes2/vendor/fontawesome-free/css/all.min.css" rel="stylesheet" type="text/css">
    <link href="https://fonts.googleapis.com/css?family=Nunito:200,200i,300,300i,400,400i,600,600i,700,700i,800,800i,900,900i"
          rel="stylesheet">

    <!-- Custom styles for this template-->
    <link href="~/Assets/Themes2/css/sb-admin-2.min.css" rel="stylesheet">
	<link href="~/assets/admin/css.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/css/bootstrap.min.css">
   
    <style>
        .carousel-inner {
            margin-bottom: 20px;
            margin-top: 20px;
        }

        .carousel-control {
            opacity: 0;
            transition: opacity 0.5s;
        }

        .carousel:hover .carousel-control {
            opacity: 1;
        }
    </style>
</head>

<body>
    <style>
        #loading {
            background-color: white;
            position: fixed;
            display: block;
            top: 0;
            bottom: 0;
            z-index: 1000000;
            opacity: 0.5;
            width: 100%;
            height: 100%;
            text-align: center;
        }

            #loading img {
                width: 300px;
                height: 300px;
                margin: auto;
                display: block;
                top: calc(30% );
                left: calc(40% );
                position: absolute;
                z-index: 999999;
            }

        .no-wrap {
            white-space: nowrap;
        }
    </style>
    <div id="loading" style="display:none">
        <img src="~/Assets/admin/Animation - 1704819851844.gif" alt="Loading..." />
    </div>
    <div class="container-fluid">
        <nav class="navbar navbar-light bg-light">
        <div class="container-fluid">
            <a class="navbar-brand">Home</a>
            <form class="d-flex position-relative">
                            @Html.Raw(ViewBag.Login)
                </form>
            </div>
        </nav>
        <div class="container-fluid">
            @RenderBody()
        </div>
       


    </div>

    <footer class="sticky-footer bg-white">
        <div class="container my-auto">
            <div class="copyright text-center my-auto">
                <span>Copyright &copy; Your Website 2021</span>
            </div>
        </div>
    </footer>



    <!-- Bootstrap core JavaScript-->
    <script src="~/Assets/Themes2/vendor/jquery/jquery.min.js"></script>
    <script src="~/Assets/Themes2/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>

    <!-- Core plugin JavaScript-->
    <script src="~/Assets/Themes2/vendor/jquery-easing/jquery.easing.min.js"></script>

    <!-- Custom scripts for all pages-->
    <script src="~/Assets/Themes2/js/sb-admin-2.min.js"></script>
    <script src="~/Assets/admin/_layout.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js" integrity="sha384-geWF76RCwLtnZ8qwWowPQNguL3RmwHVBC9FhGdlKrxdiJJigb/j/68SIy3Te4Bkz" crossorigin="anonymous"></script>
    
    
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/js/bootstrap.min.js"></script>

    <script>
        $(document).ready(function () {
            var $carousel = $('.carousel');

            $carousel.carousel({
                interval: 500
            });

            $carousel.hover(
                function () {
                    $(this).find('.carousel-control').fadeIn('fast');
                },
                function () {
                    $(this).find('.carousel-control').fadeOut('fast');
                }
            );
        });
        var x = {
            init: function () {
                
                $("#logout").click(function () {
                    x.logout();
                });

            },

            logout: function () {
                $.ajax({
                    type: 'get',
                    dataType: 'json',
                    contentType: false,
                    processData: false,
                   
                    url: '/Home/Logout/',
                    success: function (res) {
                        window.location.href = "/Login/Index";
                      
                    },
                });
            },
        };
        x.init();
    </script>
    @RenderSection("scripts", required: false)
</body>

</html>