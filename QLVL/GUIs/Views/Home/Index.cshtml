
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<!-- Header End -->
<div class="container-xxl py-5 bg-dark page-header mb-5">
    <div class="container my-5 pt-5 pb-4">
        <h1 class="display-3 text-white mb-3 animated slideInDown">
            Công việc
        </h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb text-uppercase">
                <li class="breadcrumb-item"><a href="#">Home</a></li>
                <li class="breadcrumb-item"><a href="#">Pages</a></li>
                <li class="breadcrumb-item text-white active" aria-current="page">
                    Job List
                </li>
            </ol>
        </nav>
    </div>
</div>
<!-- Header End -->


<div class="row">
    <div class="col-md-1">

    </div>
    <div class="col-md-10">
       


        <div class="row">
            <div class="col-md-4">
                <input type="text" class="form-control p-4 m-4" id="search" placeholder="Tìm kiếm công việc" />
            </div>
        </div>

 @*        <div class="container-fluid">


            <div class="row">
                <h1>Gợi ý công việc </h1>
            </div>
            <div class="row" id="data"></div>
        </div> *@
        <div class="container-xxl py-5">
            <div class="container">
                <h1 class="text-center mb-5 wow fadeInUp" data-wow-delay="0.1s">
                    Danh mục công việc
                </h1>
                <hr />
                <div class="row g-4" id="data">

                </div>
            </div>
        </div>
        <!-- Category End -->


        <div class="container-fluid">




            <div class="row p-2">
                <div class="row">
                    <h1 style="text-align:center">Danh sách các công việc</h1>
                    <hr />
                </div>
            </div>

            <div class="row">
                <div class="col-md-2">
                    <span>Số dòng/trang</span>
                </div>
                <div class="col-md-2">

                    @Html.DropDownList("Pagesize", new SelectList(ViewBag.Pagesize, "ID", "ID"), new { @class = "form-control" })
                </div>
                <div class="col-md-2">
                    <span>Tháng</span>
                </div>
                <div class="col-md-2">
                    @Html.DropDownList("Month", new SelectList(ViewBag.Month, "month", "month"), new { @class = "form-control" })
                </div>

                <div class="col-md-2">
                    <span>Năm</span>
                </div>
                <div class="col-md-2">
                    @Html.DropDownList("Year", new SelectList(ViewBag.Year, "year", "year"), new { @class = "form-control" })
                </div>

            </div>

           
            <div class="container-xxl py-5">
                <div class="container">
                    <h1 class="text-center mb-5 wow fadeInUp" data-wow-delay="0.1s">
                        Danh sách công việc
                    </h1>
                    <hr />
                    <div class="tab-class text-center wow fadeInUp" data-wow-delay="0.3s">
                        <div class="tab-content">
                            <div class="tab-pane fade show p-0 active" id="tbData">
                               
                            </div>
                        </div>
                    </div>
                </div>
            </div>


            <table>
                <tfoot>
                    <tr>
                        <th colspan="100" id="pages"></th>
                    </tr>
                </tfoot>
            </table>
        </div>

    </div>
    <div class="col-md-1">
    </div>
</div>

@section scripts {
    <script>
        var nguoilaodong = {
            init: function () {

                nguoilaodong.search(1);
                nguoilaodong.ListNhomCongViec();
                $("#search").change(function () {
                    nguoilaodong.search(1);
                });
                $("#Pagesize").change(function () {
                    nguoilaodong.search(1);
                });

                $("#Month").change(function () {
                    nguoilaodong.search(1);
                });
                $("#Year").change(function () {
                    nguoilaodong.search(1);
                });
            },

            search: function (index) {
                var name = $("#search").val();
                var size = $("#Pagesize").val();
                var thang = $("#Month").val();
                var nam = $("#Year").val();
                var arr = "";
                $('.namecate:checked').each(function () {
                    arr +="-" + $(this).val();
                });
                
                var form = new FormData();
                form.append("name", name);
                form.append("size", size);
                form.append("index", index);
                form.append("thang", thang);
                form.append("nam", nam);
                form.append("arr", arr);
              
                $.ajax({
                    type: 'POST',
                    dataType: 'json',
                    contentType: false,
                    processData: false,
                    data: form,
                    url: '/Home/ShowList/',
                    success: function (res) {
                        var html = "";
                        $.each(res.data, function (index, a) {
                           
                            html += "<div class='job-item p-4 mb-4'>";
                            html += "<div class='row g-4'>";
                            html += "<div class='col-sm-12 col-md-8 d-flex align-items-center'>";
                            // html += "<img class='flex-shrink-0 img-fluid border rounded' src='img/com-logo-5.jpg' alt='' style='width: 80px; height: 80px' />"
                            html += "<div class='text-start ps-4'>";
                            html += "<h5 class='mb-3'>" + a.name + "</h5>";
                            html += "<span class='text-truncate me-3'>";
                            html += "<i class='fa fa-map-marker-alt text-primary me-2'></i>" + a.address + "";
                            html += "</span>";
                            html += "<span class='text-truncate me-3'>";
                            html += "<i class='far fa-clock text-primary me-2'></i>Bắt đầu: " + a.timeworkS + "";
                            html += "</span>";
                            html += "<span class='text-truncate me-3'>";
                            html += "<i class='far fa-clock text-primary me-2'></i>Kết thúc: " + a.finishS + "";
                            html += "</span>";
                            html += "<span class='text-truncate me-0'>";
                            html += "<i class='far fa-money-bill-alt text-primary me-2'></i>Lương đề xuất: " + a.salary + " VND";
                            html += "</span>";
                            html += "</div>";
                            html += "</div>";
                            html += "<div class='col-sm-12 col-md-4 d-flex flex-column align-items-start align-items-md-end justify-content-center'>";
                            html += "<div class='d-flex mb-3'>";
                            html += "<a class='btn btn-light btn-square me-3' href=''>";
                            html += "<i class='far fa-heart text-primary'></i>";
                            html += "</a>";
                            html += "<a class='btn btn-primary' href='/Home/ChiTietCongViec/" + a.id + "'>Xem chi tiết công việc</a>";
                            html += "</div>";
                            html += "<small class='text-truncate'>";
                            html += "<i class='far fa-calendar-alt text-primary me-2'></i>Date Line: 01 Jan, 2045";
                            html += "</small>";
                            html += "</div>";
                            html += "</div>";
                            html += "</div>";
                        });
                        $("#tbData").html(html);
                        $("#pages").html(res.page);
                       
                    },
                });
            },
            ListNhomCongViec: function () {
                $.ajax({
                    type: 'POST',
                    dataType: 'json',
                    contentType: false,
                    processData: false,

                    url: '/Home/ListNhomCongViec/',
                    success: function (res) {
                        var html = "";
                        $.each(res.data, function (index, a) {
                            // html += "<div class='col-md-2'>";
                            // html += "<div class='form-check' style='display: flex; align-items: center;'>";
                            // html += "<input type='checkbox' value='" + a.id + "' class='namecate m-2' onchange='nguoilaodong.search(1)' style='margin-right: 5px;'/>";
                            // html += "<label class='' style='font-weight: 100;font-size:15px'>" + a.name + "</label>";
                            // html += "</div>";
                            // html += "</div>";
                            html += "<div class='col-lg-3 col-sm-6 wow fadeInUp' data-wow-delay='0.1s'>";
                            html += "<div class='cat-item rounded p-4' href=''>";
                            html += "<div class='row'> <div class='col-10'>";

                            html += "<h6 class='mb-3'>"+a.name+"</h6>";
                            html += "<p class='mb-0'>123 Công việc</p>";
                            html += "</div>";
                            html += "<div class='col-2'>";
                            html += "<input type='checkbox' value='" + a.id + "' class='namecate m-2' onchange='nguoilaodong.search(1)' style='width: 20px; height: 20px'/>";
                            html += " </div>";
                            
                            html += "</div>";
                            html += "</div>";
                            html += "</div>";
                            html += " </div>";

                         


                        });
                        $("#data").html(html);
                    },
                });
            },

        };

        nguoilaodong.init();

        function goto(i) {
            nguoilaodong.search(i);
        }
    </script>
}
