
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="container">
    <div class="row">
        <div class="col-md-8">
            <div id="myCarousel" class="carousel slide" data-ride="carousel" style="max-width:900px; max-height: 250px;">
                <div class="carousel-inner">
                    <div class="item active">
                        <img src="https://cellphones.com.vn/media/wysiwyg/slide/06_17/Khai-truong-Banner-web_Landing_2000x700.jpg" alt="Los Angeles" style="width:100%; max-height: 250px;">
                    </div>
                    <div class="item">
                        <img src="https://webmedia.com.vn/images/2020/05/banner-slide-laptop-moi-gia-re-nhat-quang-ninh.jpg" alt="Chicago" style="width:100%; max-height: 250px;">
                    </div>
                    <div class="item">
                        <img src="https://anphat.com.vn/media/lib/29-04-2023/laptop.jpg" alt="New york" style="width:100%; max-height: 250px;">
                    </div>
                    <div class="item">
                        <img src="https://cdn-img-v2.webbnc.net/uploadv2/web/82/8269/media/2020/11/15/10/28/1605449277_untitled-312.png" alt="New york" style="width:100%; max-height: 250px;">
                    </div>
                </div>

                <a class="left carousel-control" href="#myCarousel" data-slide="prev">
                    <span class="glyphicon glyphicon-chevron-left"></span>
                    <span class="sr-only">Previous</span>
                </a>
                <a class="right carousel-control" href="#myCarousel" data-slide="next">
                    <span class="glyphicon glyphicon-chevron-right"></span>
                    <span class="sr-only">Next</span>
                </a>
            </div>
        </div>
        <div class="col-md-4">
            <!-- Khung slide bên phải -->
            <div id="rightCarousel" class="carousel slide" data-ride="carousel" style="max-width:500px; max-height: 250px;">
                <div class="carousel-inner">
                    <div class="item active">
                        <img src="https://datacare.vn/wp-content/uploads/2020/11/Banner-Cong-nghe-NA1611202040.jpg" alt="Right Slide 1" style="width:100%; max-height: 250px;">
                    </div>
                    <div class="item">
                        <img src="https://datacare.vn/wp-content/uploads/2020/11/Banner-Am-Nhac-%E2%80%93-LVHB0911202015.jpg" alt="Right Slide 2" style="width:100%; max-height: 250px;">
                    </div>
                    <div class="item">
                        <img src="https://img.pikbest.com/origin/06/04/96/40BpIkbEsTC9e.jpg!bw700" alt="Right Slide 3" style="width:100%; max-height: 250px;">
                    </div>
                    <div class="item">
                        <img src="https://img.pikbest.com/origin/05/94/30/94dpIkbEsTacD.jpg!bw700" alt="Right Slide 4" style="width:100%; max-height: 250px;">
                    </div>
                    <div class="item">
                        <img src="https://my-test-11.slatic.net/p/637b317e0d9e6cce4f99ab4f9bc16788.jpg" alt="Right Slide 5" style="width:100%; max-height: 250px;">
                    </div>
                </div>
                <a class="left carousel-control" href="#rightCarousel" data-slide="prev">
                    <span class="glyphicon glyphicon-chevron-left"></span>
                    <span class="sr-only">Previous</span>
                </a>
                <a class="right carousel-control" href="#rightCarousel" data-slide="next">
                    <span class="glyphicon glyphicon-chevron-right"></span>
                    <span class="sr-only">Next</span>
                </a>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid">

    <div class="row">
        <div class="col-md-4" style="text-align:center">
            <input type="text" class="form-control p-4 m-4" id="search" placeholder="Tìm kiếm công việc" />
        </div>
    </div>


    <div class="row p-2">
        <div class="col-md-2">
            <span>Số dòng/trang</span>
        </div>
        <div class="col-md-2">

            @Html.DropDownList("Pagesize", new SelectList(ViewBag.Pagesize, "ID", "ID"), new { @class = "form-control" })
        </div>
        <div class="col-md-2">
            <span>Tháng</span>
        </div>
        <div class="col-md-2">
            @Html.DropDownList("Month", new SelectList(ViewBag.Month, "month", "month"), new { @class = "form-control" })
        </div>

        <div class="col-md-2">
            <span>Năm</span>
        </div>
        <div class="col-md-2">
            @Html.DropDownList("Year", new SelectList(ViewBag.Year, "year", "year"), new { @class = "form-control" })
        </div>
    </div>

    <div class="row" style="text-align:center">
        <h1>Danh sách các công việc</h1>
    </div>
    <div class="row" id="tbData"></div>

    <table>
        <tfoot>
            <tr>
                <th colspan="100" id="pages"></th>
            </tr>
        </tfoot>
    </table>
</div>

@section scripts {
    <script>
        var nguoilaodong = {
            init: function () {
                nguoilaodong.search(1);
                $("#search").change(function () {
                    nguoilaodong.search(1);
                });
                $("#Pagesize").change(function () {
                    nguoilaodong.search(1);
                });
                $("#Month").change(function () {
                    nguoilaodong.search(1);
                });
                $("#Year").change(function () {
                    nguoilaodong.search(1);
                });
            },

            search: function (index) {
                var name = $("#search").val();
                var size = $("#Pagesize").val();
                var thang = $("#Month").val();
                var nam = $("#Year").val();
                var form = new FormData();
                form.append("name", name);
                form.append("size", size);
                form.append("index", index);
                form.append("thang", thang);
                form.append("nam", nam);
              
                $.ajax({
                    type: 'POST',
                    dataType: 'json',
                    contentType: false,
                    processData: false,
                    data: form,
                    url: '/Home/ShowList/',
                    success: function (res) {
                        var html = "";
                        $.each(res.data, function (index, a) {
                            html += "<div class='col-md-4 text-center p-3'>";
                            html += "<div class='box'>";
                            html += "<div class='avatar'>";
                            html += "<img src='https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcRwseavjwRpeAJjNIJM7JRLwGUpAQiRDqFh1g&usqp=CAU' alt='' class='img-fluid' />";
                            html += "</div>";
                            html += "<div class='box_content'>";
                            html += "<h2 style=' text-align: center;'>" + a.name + "</h2>";
                            html += "<div class='col-md-6'>";
                            html += "<p style='font-size: 18px;'>Tuyển dụng " + a.name + "</p>";
                            html += "<p style='font-size: 18px;'>Độ Tuổi từ: " + a.mintuoi + " Đến: " + a.maxtuoi + "</p>";
                            html += "<p style='font-size: 18px;'>Địa chỉ: " + a.address + "</p>";
                            html += "</div>";
                            html += "<div class='col-md-6'>";
                            html += "<p style='font-size: 18px;'>Thời gian bắt đầu: " + a.timeworkS + "</p>";
                         
                            html += "<p style='font-size: 18px;'>Lương đề xuất: " + a.salary + "</p>";
                            html += "</div>";
                            html+="<div class='row'>"
                            html += "<ul class='icons' >";
                            html += "<li><a href='/Home/ChiTietCongViec/" + a.id + "' class='btn btn-primary'>Xem chi tiết công việc</a></li>";
                            html += "</ul>";
                            html+="</div>"
                            html += "</div>";
                            html += "</div>";
                            html += "</div>";
                        });
                        $("#tbData").html(html);
                        $("#pages").html(res.page);
                       
                    },
                });
            },
        };

        nguoilaodong.init();

        function goto(i) {
            nguoilaodong.search(i);
        }
    </script>
}