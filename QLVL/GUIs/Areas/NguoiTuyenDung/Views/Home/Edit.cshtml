
@{
    ViewData["Title"] = "Edit";
    Layout = "~/Views/Shared/_Login.cshtml";
}


<div class="text-center">
    <h1 class="h4 text-gray-900 mb-4">Cập nhật thông tin cá nhân</h1>
</div>
<form class="user">
    <div class="form-group">
        <label>Họ và tên</label>
        <input type="text" class="form-control form-control-user" id="name"
               placeholder="Họ và tên">
    </div>

    <div class="form-group">
        <label>Địa chỉ</label>
        <input type="text" class="form-control form-control-user" id="address"
               placeholder="Địa chỉ">
    </div>

    <div class="form-group">
        <label>Số điện thoại</label>
        <input type="text" class="form-control form-control-user" id="sdt"
               placeholder="Số điện thoại">
    </div>
    <div class="form-group">
        <label>Fanpage (Nếu có)</label>
        <input type="text" class="form-control form-control-user" id="fanpage"
               placeholder="Fanpage (Nếu có)">
    </div>

    <div class="form-group">
        <label>Email</label>
        <input type="email" class="form-control form-control-user" id="email"
               placeholder="Email Address" readonly="readonly">
    </div>
    <div class="form-group">
        <label>Mô tả</label>
        <textarea type="text" class="form-control form-control-user" id="introduce"
                  placeholder="Mô tả"></textarea>
    </div>
    <div class="form-group">
        <label>Ảnh đại diện</label>
        <input type="text" class="form-control form-control-user" id="image"
               placeholder="Ảnh đại diện">
    </div>
    <div class="form-group">

        <img src="" alt="Hình ảnh " class="img-fluid" id="img" />
    </div>
   

  
    <input type="button" class="btn btn-primary" id="login" value=" Cập nhật" />
    <a href="/NguoiTuyenDung/Home/Index" class="btn btn-danger" value=" ">Quay lại</a>




</form>
<hr>


@section scripts {
    <script>
        var login = {
            init: function () {
                login.getNguoiTuyenDung();
                $("#login").click(function () {

                    login.dangky();
                });

            },
            dangky: function () {
                var name = $("#name").val();
                var sdt = $("#sdt").val();
                var fanpage = $("#fanpage").val();
                var address = $("#address").val();
                var image = $("#image").val();
                var introduce = $("#introduce").val();
               
               
               
                if (!name || !sdt || !address||!image||!introduce) {
                    alert("Vui lòng điền đầy đủ thông tin.");
                    return;
                }

                var form = new FormData()
                form.append("name", name);
                form.append("sdt", sdt);
                form.append("fanpage", fanpage);
                form.append("address", address);
                form.append("image", image);
                form.append("introduce", introduce);
               
                $("#loading").show();
                $.ajax({
                    type: 'POST',
                    dataType: 'Json',
                    contentType: false,
                    processData: false,
                    data: form,
                    url: '/NguoiTuyenDung/Home/Update/',
                    success: function (res) {
                        alert(res.mess);
                       
                        $("#loading").hide();
                    },
                    error: function () {

                    }

                });
            },
            getNguoiTuyenDung: function () {
                $.ajax({
                    type: 'get',
                    dataType: 'Json',
                    contentType: false,
                    processData: false,
                    
                    url: '/NguoiTuyenDung/Home/getNguoiTuyenDung/',
                    success: function (res) {
                        $("#name").val(res.data.name);
                        $("#address").val(res.data.diachi);
                        $("#sdt").val(res.data.sdt);
                        $("#fanpage").val(res.data.fanpage);
                        $("#email").val(res.data.email);
                        $("#image").val(res.data.image);
                        $("#introduce").val(res.data.introduce);
                        $("#img").attr("src", res.data.image);
                    },
                    error: function () {

                    }

                });
            }
        }
        login.init();
    </script>
}

